# ── Salesforce ──────────────────────────────
SF_CONSUMER_KEY=REPLACE_WITH_CONSUMER_KEY
# Private key format: Use double quotes and \n for newlines (recommended).
# Both PKCS#8 (BEGIN PRIVATE KEY) and traditional RSA (BEGIN RSA PRIVATE KEY) are supported.
# Example: SF_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
SF_PRIVATE_KEY_PEM="REPLACE_WITH_PRIVATE_KEY_PEM"
SF_USERNAME=integration@yourorg.com
SF_LOGIN_URL=https://test.salesforce.com

# ── Flask ────────────────────────────────────
FLASK_DEBUG=true
SECRET_KEY=REPLACE_WITH_32_CHAR_SECRET
ENVIRONMENT=dev
LOG_LEVEL=DEBUG
ALLOWED_ORIGINS=http://localhost:3000

# ── HMAC Auth ────────────────────────────────
HMAC_ENABLED=true
HMAC_SECRET_KEY_CORE=REPLACE_WITH_CORE_HMAC_KEY
HMAC_SECRET_KEY_ENGINEER=REPLACE_WITH_ENGINEER_HMAC_KEY

# ── MinIO ────────────────────────────────────
MINIO_ENABLED=true
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=salesforce-dev
MINIO_SECURE=false

# ── Kafka ────────────────────────────────────
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/salesforce_service

# ── ClickHouse ───────────────────────────────
CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9440

# ── Service ──────────────────────────────────
MAX_CONCURRENT_SCANS=5
SF_MAX_JOB_TIMEOUT_HOURS=2
PII_MASKING_ENABLED=false
PII_HMAC_KEY=REPLACE_WITH_PII_KEY